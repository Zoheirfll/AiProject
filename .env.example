# ==== Django ====
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ==== PostgreSQL ====
POSTGRES_DB=grh_auto
POSTGRES_USER=grh_auto
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ==== Django Channels / Redis ====
REDIS_URL=redis://redis:6379/0

# ==== Ollama ====
# Ollama runs on the HOST, not in Docker. docker-compose.yml overrides this
# to http://host.docker.internal:11434 for the backend container — this
# value is only used when running the backend outside Docker.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ==== n8n ====
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=change-me-32-chars-min
N8N_WEBHOOK_URL=http://n8n:5678/

# ==== SMTP (Gmail) ====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=app-password-here

# ==== Frontend ====
VITE_API_URL=http://localhost:8000
VITE_GRAPHQL_URL=http://localhost:8000/graphql
VITE_WS_URL=ws://localhost:8000/ws
