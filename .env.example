# ==== Django ====
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ==== PostgreSQL ====
POSTGRES_DB=grh_auto
POSTGRES_USER=grh_auto
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ==== Django Channels / Redis ====
REDIS_URL=redis://redis:6379/0

# ==== Ollama ====
# Ollama runs on the HOST, not in Docker. docker-compose.yml overrides this
# to http://host.docker.internal:11434 for the backend container — this
# value is only used when running the backend outside Docker.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Smaller/faster model for document-surveillance analysis (larger inputs,
# frequent runs) — keep this a lightweight model on CPU-only setups.
OLLAMA_SURVEILLANCE_MODEL=qwen2.5:1.5b

# ==== n8n ====
# US-E7-01: set this to the PC's actual LAN IP (e.g. 192.168.1.42) so the
# HR team can reach n8n from other machines at http://<IP-PC>:5678 — n8n
# itself always listens on 0.0.0.0 inside the container (N8N_LISTEN_ADDRESS
# in docker-compose.yml), "localhost" here only affects generated URLs.
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=change-me-32-chars-min
N8N_WEBHOOK_URL=http://n8n:5678/
# Used by the dashboard's n8n health check. Default reaches the n8n
# container by its Docker Compose service name; override only if running
# the backend outside Docker.
N8N_INTERNAL_URL=http://n8n:5678
# US-E7-02: static bearer token n8n sends as "Authorization: Bearer <token>"
# to call GRH-Auto's /api/n8n/* endpoints. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
N8N_API_TOKEN=change-me-generate-a-real-token

# ==== SMTP (Gmail) ====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=app-password-here

# ==== Frontend ====
VITE_API_URL=http://localhost:8000
VITE_GRAPHQL_URL=http://localhost:8000/graphql
VITE_WS_URL=ws://localhost:8000/ws
# US-E7-04: n8n link in the sidebar, opened in a new tab.
VITE_N8N_URL=http://localhost:5678
